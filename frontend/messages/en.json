    "feature3Body": "Once she agrees, we compute the midpoint and suggest a partner cafe. With our promo code — a discount.",
    "manifesto": {
      "kicker": "Manifesto",
      "title": "Not swipes. Words.",
      "body": "We’re tired of apps where matched ≠ understood. Mattcha brings back an old rule: one chance to impress, one chance to meet. The message limit isn’t a bug, it’s the feature: it forces you to think before you type. The rest is just decor.",
      "signature": "— the mattcha team"
    },
    "faq": {
      "kicker": "FAQ",
      "title": "Frequently asked",
      "items": [
        {
          "q": "What if 15 messages aren’t enough?",
          "a": "She can extend the limit by +15, +30, a custom number, or make it unlimited. Only she decides."
        },
        {
          "q": "And if she agrees?",
          "a": "We open a list of partner venues at the midpoint between you, with promo-code discounts. The rest is offline."
        },
        {
          "q": "Can I remove the limit upfront?",
          "a": "No. It’s part of the format. Only she can extend, and only after a chat starts."
        },
        {
          "q": "Who sees my profile?",
          "a": "Only the opposite sex. No promo feeds, no sponsored cards."
        }
      ]
